@prefix : <http://example.org/dlt-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix iso: <http://iso.org/iso-ts-23258#> .

# =====================================================
# DLT / Blockchain Ontology (Turtle/OWL)
# Based on ISO/TS 23258:2021 Taxonomy and Ontology
# For Snowflake Agentic Demo + Interoperability
# =====================================================

:DLTOntology a owl:Ontology ;
    rdfs:label "DLT Blockchain Ontology based on ISO/TS 23258:2021" ;
    rdfs:comment "Core classes, properties, and relations for blockchain and distributed ledger technologies. Designed for relational mapping in Snowflake and semantic reasoning with Cortex Agents." .

# =====================================================
# Core Classes (from ISO Clause 6)
# =====================================================

:Ledger a owl:Class ;
    rdfs:label "Ledger" ;
    rdfs:comment "A record of transactions or data entries shared and maintained by multiple participants." ;
    rdfs:subClassOf owl:Thing .

:DistributedLedger a owl:Class ;
    rdfs:label "Distributed Ledger" ;
    rdfs:comment "A decentralized ledger shared across multiple nodes without central authority." ;
    rdfs:subClassOf :Ledger .

:Blockchain a owl:Class ;
    rdfs:label "Blockchain" ;
    rdfs:comment "A type of distributed ledger where data is stored in cryptographically linked blocks." ;
    rdfs:subClassOf :DistributedLedger .

:Block a owl:Class ;
    rdfs:label "Block" ;
    rdfs:comment "A data structure grouping transactions, linked to the previous block via cryptographic hash." ;
    rdfs:subClassOf owl:Thing .

:Transaction a owl:Class ;
    rdfs:label "Transaction" ;
    rdfs:comment "A record of value transfer or state change recorded in a block." .

:DLTNode a owl:Class ;
    rdfs:label "DLT Node" ;
    rdfs:comment "A participant in the distributed ledger network (validator, miner, full node, etc.)." .

:ConsensusMechanism a owl:Class ;
    rdfs:label "Consensus Mechanism" ;
    rdfs:comment "Protocol for achieving agreement on the state of the ledger (e.g., PoW, PoS, BFT)." .

:SmartContract a owl:Class ;
    rdfs:label "Smart Contract" ;
    rdfs:comment "Self-executing code deployed on the blockchain (stateful or stateless)." .

:Token a owl:Class ;
    rdfs:label "Token" ;
    rdfs:comment "Digital asset on the blockchain (native cryptocurrency, fungible, or non-fungible token)." .

# =====================================================
# Object Properties (Relations)
# =====================================================

:hasBlock a owl:ObjectProperty ;
    rdfs:label "has Block" ;
    rdfs:domain :Blockchain ;
    rdfs:range :Block ;
    rdfs:comment "A blockchain contains one or more blocks." .

:hasTransaction a owl:ObjectProperty ;
    rdfs:label "has Transaction" ;
    rdfs:domain :Block ;
    rdfs:range :Transaction ;
    rdfs:comment "A block contains transactions." .

:previousBlock a owl:ObjectProperty ;
    rdfs:label "previous Block" ;
    rdfs:domain :Block ;
    rdfs:range :Block ;
    rdfs:comment "Links a block to its predecessor via hash." .

:usesConsensus a owl:ObjectProperty ;
    rdfs:label "uses Consensus" ;
    rdfs:domain :Blockchain ;
    rdfs:range :ConsensusMechanism .

:hasNode a owl:ObjectProperty ;
    rdfs:label "has Node" ;
    rdfs:domain :Blockchain ;
    rdfs:range :DLTNode .

:deployedOn a owl:ObjectProperty ;
    rdfs:label "deployed On" ;
    rdfs:domain :SmartContract ;
    rdfs:range :Blockchain .

:issuedOn a owl:ObjectProperty ;
    rdfs:label "issued On" ;
    rdfs:domain :Token ;
    rdfs:range :Blockchain .

# =====================================================
# Data Properties (Attributes)
# =====================================================

:blockNumber a owl:DatatypeProperty ;
    rdfs:label "block Number" ;
    rdfs:domain :Block ;
    rdfs:range xsd:integer .

:blockHash a owl:DatatypeProperty ;
    rdfs:label "block Hash" ;
    rdfs:domain :Block ;
    rdfs:range xsd:string .

:merkleRoot a owl:DatatypeProperty ;
    rdfs:label "Merkle Root" ;
    rdfs:domain :Block ;
    rdfs:range xsd:string .

:nonce a owl:DatatypeProperty ;
    rdfs:label "nonce" ;
    rdfs:domain :Block ;
    rdfs:range xsd:string .

:timestamp a owl:DatatypeProperty ;
    rdfs:label "timestamp" ;
    rdfs:domain :Block ;
    rdfs:range xsd:dateTime .

:status a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:domain :Block ;
    rdfs:range xsd:string .  # Confirmed, Validated, Pending

:txHash a owl:DatatypeProperty ;
    rdfs:label "transaction Hash" ;
    rdfs:domain :Transaction ;
    rdfs:range xsd:string .

:value a owl:DatatypeProperty ;
    rdfs:label "value" ;
    rdfs:domain :Transaction ;
    rdfs:range xsd:decimal .

:nodeType a owl:DatatypeProperty ;
    rdfs:label "node Type" ;
    rdfs:domain :DLTNode ;
    rdfs:range xsd:string .  # Validator, Miner, Full Node, etc.

:consensusName a owl:DatatypeProperty ;
    rdfs:label "consensus Name" ;
    rdfs:domain :ConsensusMechanism ;
    rdfs:range xsd:string .  # PoW, PoS, BFT, etc.

:tokenSymbol a owl:DatatypeProperty ;
    rdfs:label "token Symbol" ;
    rdfs:domain :Token ;
    rdfs:range xsd:string .

:tokenType a owl:DatatypeProperty ;
    rdfs:label "token Type" ;
    rdfs:domain :Token ;
    rdfs:range xsd:string .  # Native, Fungible (ERC-20), Non-Fungible (ERC-721)

# =====================================================
# Axioms / Restrictions (simplified)
# =====================================================

:Blockchain rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasBlock ;
    owl:someValuesFrom :Block
] .

:Block rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :previousBlock ;
    owl:maxCardinality 1
] .

# =====================================================
# Individuals / Examples (for demo)
# =====================================================

:Bitcoin a :Blockchain ;
    rdfs:label "Bitcoin" ;
    :usesConsensus :PoW .

:Ethereum a :Blockchain ;
    rdfs:label "Ethereum" ;
    :usesConsensus :PoS .

:PoW a :ConsensusMechanism ;
    :consensusName "Proof of Work (PoW)" .

:PoS a :ConsensusMechanism ;
    :consensusName "Proof of Stake (PoS)" .

:GenesisBlockBTC a :Block ;
    :blockNumber 0 ;
    :blockHash "000000000019d6689c085ae165831e934ff763ae46a2a6c172b3f1b60a8ce26f" ;
    :timestamp "2009-01-03T18:15:05Z"^^xsd:dateTime ;
    :isGenesis true .

# =====================================================
# Notes for Snowflake Integration
# =====================================================
# - Map classes to Snowflake tables or semantic view entities.
# - Use this OWL for interoperability with tools like Protégé, Graph databases, or Cortex Code skills.
# - Extend with domain-specific properties (e.g., exchange-specific trading data) as needed.
# - For full agentic demo: Load into Snowflake, create semantic view, and query via Cortex Agent with natural language.

# End of DLT Blockchain Ontology